# Redis Connection
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=30
REDIS_SOCKET_CONNECT_TIMEOUT=30

# API
API_HOST=127.0.0.1
API_PORT=8001
RELOAD=false

# Collection
PUBLIC_MAX_SIGNATURES=100000
COMPRESSION_LEVEL=9

# Admin
ADMIN_API_KEY=your-sha256-hashed-key-here

# Rate Limit
RATE_LIMIT_DEFAULT=30
RATE_LIMIT_WINDOW=60
EOF